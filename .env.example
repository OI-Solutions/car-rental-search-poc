# -----------------------------------------------------------------------------
# LOCAL DEVELOPMENT CONFIGURATION ONLY — DO NOT USE IN PRODUCTION
# -----------------------------------------------------------------------------
# Copy this file to `.env` and adjust as needed:
#     cp .env.example .env
# `.env` is git-ignored so real values are never committed.
# -----------------------------------------------------------------------------

# Admin password the OpenSearch security plugin bootstraps on first start.
# Must satisfy the strong-password policy (>=8 chars, upper, lower, digit, symbol).
# CHANGE THIS before running anything you care about.
OPENSEARCH_INITIAL_ADMIN_PASSWORD=Dev_Passw0rd!23

# How the Python scripts reach OpenSearch from the host.
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_SCHEME=https
OPENSEARCH_USERNAME=admin
# Keep this in sync with OPENSEARCH_INITIAL_ADMIN_PASSWORD above.
OPENSEARCH_PASSWORD=Dev_Passw0rd!23

# The security plugin uses a self-signed demo certificate in local dev, so the
# Python clients skip TLS verification. Never do this against a real cluster.
OPENSEARCH_VERIFY_CERTS=false

# Auth mode for talking to OpenSearch: "basic" (default, username/password via
# the security plugin — what local Docker OpenSearch uses) or "sigv4" (AWS IAM
# request signing — required by OpenSearch Serverless, and by IAM-auth-enabled
# OpenSearch Service domains). In "sigv4" mode, OPENSEARCH_USERNAME/PASSWORD are
# ignored; AWS credentials come from the standard SDK provider chain
# (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / AWS_SESSION_TOKEN, or an
# instance/task role) and OPENSEARCH_HOST should be the collection/domain
# endpoint host (no scheme), e.g. xxxxxxxx.aoss.us-east-1.on.aws.
OPENSEARCH_AUTH_MODE=basic

# Region + service for sigv4 signing only. "aoss" = OpenSearch Serverless,
# "es" = a managed OpenSearch Service domain with IAM auth.
OPENSEARCH_REGION=us-east-1
OPENSEARCH_SERVICE=aoss

# OpenSearch Dashboards host port.
DASHBOARDS_PORT=5601

# JVM heap for the single OpenSearch node (min = max recommended).
OS_HEAP=512m

# -----------------------------------------------------------------------------
# Phase 2 — application layer (Express API + React frontend). LOCAL DEV ONLY.
# -----------------------------------------------------------------------------

# Port the Express API listens on.
API_PORT=4000

# Retrieval backend: "opensearch" (default) or "fixture".
#
# "fixture" serves the data/*.json corpus from memory, so the API runs with no
# cluster, no Docker, and no JVM — for demo hosts too small to run OpenSearch.
# Everything above retrieval (auth, tenant scoping, agreement pricing, redaction)
# is the real code path either way; only relevance is approximated, so BM25
# ranking of free-text queries will not match a real cluster.
#
# Left unset it defaults to "opensearch" — fixture mode must be opted into, so a
# missing env var can never silently serve fake retrieval.
SEARCH_BACKEND=opensearch

# Signing secret for the development-only mock-session JWTs.
# CHANGE THIS. It is not a real identity system; do not reuse a production secret.
JWT_DEV_SECRET=dev-only-insecure-secret-change-me

# Lifetime of a dev session token, in seconds.
JWT_TTL_SECONDS=3600

# Browser origin allowed by CORS (the Vite dev server).
CORS_ORIGIN=http://localhost:5173

# Frontend build-time config (consumed by Vite). Base URL of the Express API.
VITE_API_BASE_URL=http://localhost:4000
