{
  "settings": {
    "number_of_shards": 1,
    "number_of_replicas": 0
  },
  "mappings": {
    "dynamic": "strict",
    "properties": {
      "inventory_id": { "type": "keyword" },

      "dealership_id": { "type": "keyword" },
      "dealership_name": {
        "type": "text",
        "fields": { "keyword": { "type": "keyword" } }
      },
      "dealership_city": { "type": "keyword" },
      "dealership_state": { "type": "keyword" },
      "dealership_location": { "type": "geo_point" },

      "vehicle_model_id": { "type": "keyword" },
      "make": { "type": "keyword" },
      "model": { "type": "keyword" },
      "vehicle_class": { "type": "keyword" },
      "description": { "type": "text" },
      "seats": { "type": "integer" },
      "fuel_type": { "type": "keyword" },
      "transmission": { "type": "keyword" },
      "cargo_capacity": { "type": "keyword" },

      "quantity_available": { "type": "integer" },
      "base_daily_rate": {
        "type": "scaled_float",
        "scaling_factor": 100
      },
      "status": { "type": "keyword" },
      "last_updated": {
        "type": "date",
        "format": "strict_date_optional_time||yyyy-MM-dd"
      }
    }
  }
}
